# Planner API, optional
PLANNER_PROVIDER=api
LLM_API_BASE_URL=
LLM_API_KEY=
LLM_MODEL=
PLANNER_TIMEOUT_SECONDS=15

# History repush MySQL executor
ATG_REPUSH_MYSQL_HOST=
ATG_REPUSH_MYSQL_PORT=3306
ATG_REPUSH_MYSQL_USER=
ATG_REPUSH_MYSQL_PASSWORD=
ATG_REPUSH_MYSQL_DATABASE=
ATG_REPUSH_MYSQL_CHARSET=utf8

# Generic atomic MySQL read executor, mysql://user:password@host:3306/database?charset=utf8mb4
ATOMIC_MYSQL_DSN=

# Generic atomic HTTP executor, comma-separated host allowlist
ATOMIC_HTTP_ALLOWED_HOSTS=

# Optional cc-connect direct notification delivery
CC_CONNECT_EXE=D:\cc-connect\cc-connect-orchestrator.exe
CC_CONNECT_DATA_DIR=D:\dingdingd2Codex\data\cc-connect
